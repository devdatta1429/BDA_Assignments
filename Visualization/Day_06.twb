      <aliases enabled='yes' />
      <column caption='Total_sales' datatype='real' name='[Calculation_1303491210268673]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Sales]*[Quantity]' />
      </column>
      <column caption='Amt_after_discount' datatype='real' name='[Calculation_1303491210362882]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Sales]*(1-[Discount])' />
      </column>
      <column caption='Country_code' datatype='string' name='[Calculation_1303491210911748]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='left([Order ID],(FIND([Order ID],&quot;-&quot;,1)-1))' />
      </column>
      <column caption='Month' datatype='integer' name='[Calculation_1303491211976710]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DATEPART(&quot;month&quot;,[Order Date])' />
      </column>
      <column caption='Date_diff' datatype='integer' name='[Calculation_1303491214077959]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='DATEDIFF(&quot;day&quot;,[Order Date],today())' />
      </column>
      <column aggregation='Attribute' caption='ex1' datatype='real' name='[Calculation_1303491222528010]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{EXCLUDE [Category]: SUM([Sales])}' />
      </column>
      <column caption='Avg. include_region' datatype='real' name='[Calculation_1303491225583627]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ INCLUDE [Region]:SUM([Sales]) }' />
      </column>
      <column datatype='string' name='[Category]' role='dimension' type='nominal' />
      <column datatype='string' name='[City]' role='dimension' semantic-role='[City].[Name]' type='nominal' />
      <column caption='Country' datatype='string' name='[Country/Region]' role='dimension' semantic-role='[Country].[ISO3166_2]' type='nominal' />
      <column aggregation='Sum' datatype='integer' default-format='*00000' name='[Postal Code]' role='dimension' semantic-role='[ZipCode].[Name]' type='ordinal' />
      <column datatype='integer' name='[Row ID]' role='dimension' type='ordinal' />
      <column datatype='string' name='[State]' role='dimension' semantic-role='[State].[Name]' type='nominal' />
      <column datatype='string' name='[Sub-Category]' role='dimension' type='nominal' />
      <column caption='Orders' datatype='table' name='[__tableau_internal_object_id__].[Orders_6E70DDC0A0E44C0383C995C36B66B98C]' role='measure' type='quantitative' />
      <group name='[Category &amp; Sub-Category (Combined)]' name-style='unqualified' user:ui-builder='nest-group'>
        <groupfilter function='crossjoin'>
          <groupfilter function='level-members' level='[Category]' />
          <groupfilter function='level-members' level='[Sub-Category]' />
